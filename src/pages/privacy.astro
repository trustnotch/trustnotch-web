<style>
  .hero { padding-block-start: clamp(3rem, 8vw, 5rem); }
  .hero__sub {
    font-size: clamp(1rem, 2.5vw, 1.1875rem);
    color: var(--color-text-secondary);
    max-width: 58ch;
    margin-top: 1rem;
    line-height: 1.6;
  }
  .updated {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .prose {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .prose p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 68ch;
  }

  .subsection-title {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .mt-section { margin-top: 2.25rem; }

  .last-section { border-bottom: none; }
</style>
