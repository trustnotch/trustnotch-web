---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="TrustNotch — Tamper-evident audit logs for AI agents"
  description="Cryptographically signed, Bitcoin-anchored, and verifiable offline. TrustNotch gives AI agents tamper-evident audit logs you can prove without trusting us."
>
  <div class="page-wrapper">

    <!-- Hero -->
    <section class="section hero" aria-labelledby="hero-heading">
      <div class="hero__eyebrow section__label">Audit infrastructure for AI</div>
      <h1 id="hero-heading" class="hero__headline">
        Tamper-evident audit&nbsp;logs<br>for AI agents.
      </h1>
      <p class="hero__sub">
        Cryptographically signed, Bitcoin-anchored, and verifiable offline —
        even if TrustNotch is&nbsp;gone.
      </p>
      <div class="hero__actions">
        <a href="/trustnotch-mcp" class="btn btn-primary">MCP Server →</a>
        <a href="https://api.trustnotch.com" class="btn btn-secondary" rel="noopener noreferrer">API</a>
      </div>
    </section>

    <!-- How it works -->
    <section class="section" aria-labelledby="how-heading">
      <div class="section__label">How it works</div>
      <h2 id="how-heading" class="section__heading">Three steps from action to proof</h2>
      <ol class="steps" role="list">
        <li class="step">
          <div class="step__number" aria-hidden="true">01</div>
          <div class="step__body">
            <h3 class="step__title">Signed receipt on submission</h3>
            <p class="step__desc">
              An agent submits an action over HTTP. TrustNotch returns an
              Ed25519-signed receipt immediately — a cryptographic commitment
              to the exact content logged.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step__number" aria-hidden="true">02</div>
          <div class="step__body">
            <h3 class="step__title">Merkle-batched &amp; Bitcoin-anchored</h3>
            <p class="step__desc">
              Entries are batched into an RFC 6962 Merkle tree. Each batch root
              is anchored to Bitcoin via OpenTimestamps, giving every entry a
              tamper-evident timestamp rooted in the world's most audited ledger.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step__number" aria-hidden="true">03</div>
          <div class="step__body">
            <h3 class="step__title">Verify offline, independently</h3>
            <p class="step__desc">
              Anyone can verify any entry with the open-source
              <a href="/how-verification-works"><code>trustnotch</code> verifier</a> —
              no trust in TrustNotch required.
              The receipt, Merkle inclusion, and Bitcoin anchor are all checked
              locally. A proof keeps verifying even if TrustNotch disappears.
            </p>
          </div>
        </li>
      </ol>
    </section>

    <!-- CTA links -->
    <section class="section links-section" aria-labelledby="links-heading">
      <h2 id="links-heading" class="sr-only">Get started</h2>
      <div class="links-grid">
        <a href="/trustnotch-mcp" class="link-card">
          <span class="link-card__title">MCP Server <span aria-hidden="true">→</span></span>
          <span class="link-card__desc">Connect Claude Desktop and other MCP clients to TrustNotch.</span>
        </a>
        <a href="https://pypi.org/project/trustnotch-mcp/" class="link-card" rel="noopener noreferrer">
          <span class="link-card__title">PyPI: trustnotch-mcp <span aria-hidden="true">↗</span></span>
          <span class="link-card__desc">The MCP server package. Install with <code>pip</code> or run with <code>uvx</code>.</span>
        </a>
        <a href="https://pypi.org/project/trustnotch/" class="link-card" rel="noopener noreferrer">
          <span class="link-card__title">PyPI: trustnotch <span aria-hidden="true">↗</span></span>
          <span class="link-card__desc">The standalone offline verifier. <code>pip install trustnotch</code>.</span>
        </a>
        <a href="https://api.trustnotch.com" class="link-card" rel="noopener noreferrer">
          <span class="link-card__title">API <span aria-hidden="true">↗</span></span>
          <span class="link-card__desc">REST API at <code>api.trustnotch.com</code> — submit, fetch, and prove log entries.</span>
        </a>
      </div>
    </section>

  </div>
</Layout>

<style>
  .hero {
    padding-block-start: clamp(3rem, 8vw, 5.5rem);
    padding-block-end: clamp(2.5rem, 6vw, 4rem);
  }
  .hero__eyebrow { margin-bottom: 1.25rem; }
  .hero__headline {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .hero__sub {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-secondary);
    max-width: 55ch;
    margin-bottom: 2rem;
    line-height: 1.55;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Steps */
  .steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .step {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 1.75rem;
    background: var(--color-surface);
  }
  .step + .step { border-top: 1px solid var(--color-border); }
  .step__number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-notch-mid);
    letter-spacing: 0.05em;
    font-weight: 500;
    padding-top: 0.15rem;
    min-width: 2rem;
    flex-shrink: 0;
  }
  .step__title {
    margin-bottom: 0.4rem;
    font-size: 1rem;
  }
  .step__desc {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  /* Link cards */
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .link-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    text-decoration: none;
    transition: background 0.12s;
  }
  .link-card:hover { background: var(--color-surface-alt); }
  .link-card:focus-visible {
    outline: 2px solid var(--color-notch);
    outline-offset: -2px;
  }
  .link-card__title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    font-family: var(--font-mono);
  }
  .link-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
