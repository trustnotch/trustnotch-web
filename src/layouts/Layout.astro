---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteUrl = 'https://trustnotch.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="TrustNotch" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header" role="banner">
      <div class="site-header__inner">
        <a href="/" class="site-header__wordmark" aria-label="TrustNotch home">
          <svg class="notch-mark" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
            <rect width="14" height="14" rx="2.5" fill="#2d4a3e"/>
            <polygon points="2,2 12,2 9.5,5 2,5" fill="#e8f0ec" opacity="0.9"/>
            <rect x="2" y="6.5" width="10" height="5.5" fill="#e8f0ec" opacity="0.9"/>
          </svg>
          TrustNotch
        </a>
        <nav class="site-header__nav" aria-label="Main navigation">
          <a href="/how-verification-works">How it works</a>
          <a href="/why-it-matters">Why it matters</a>
          <a href="/trustnotch-mcp">MCP Server</a>
          <a href="/faq">FAQ</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="site-footer__inner">
        <span>© {new Date().getFullYear()} TrustNotch &mdash; Built and hosted in the EU &mdash; Helsinki, Finland</span>
        <ul class="site-footer__links">
          <li><a href="https://pypi.org/project/trustnotch/" rel="noopener noreferrer">PyPI: trustnotch</a></li>
          <li><a href="https://pypi.org/project/trustnotch-mcp/" rel="noopener noreferrer">PyPI: trustnotch-mcp</a></li>
          <li><a href="https://github.com/trustnotch" rel="noopener noreferrer">GitHub</a></li>
        </ul>
      </div>
    </footer>
  </body>
</html>
